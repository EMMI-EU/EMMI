# ─────────────────────────────────────────────────────────────────────────────
# EMMI Europe Tech — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit .env file to Git — only .env.example

# ─── Node Environment ────────────────────────────────────────────────────────
# Options: development, production, test
NODE_ENV=production

# ─── Server Configuration ────────────────────────────────────────────────────
# Port where the API server will listen
API_PORT=8080

# ─── Database Configuration ─────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
# Example: postgresql://emmi_user:secure_password@localhost:5432/emmi_db
DATABASE_URL=postgresql://username:password@localhost:5432/emmi_db

# ─── Security: JWT Secret ───────────────────────────────────────────────────
# Generate a random 48+ character string using:
# openssl rand -base64 48
# Example: aB3dE5fGhIjKlMnOpQrStUvWxYzAaBbCcDdEeFfGgHhIiJjKk
JWT_SECRET=your_random_jwt_secret_min_48_chars_here

# ─── CORS & Origin ──────────────────────────────────────────────────────────
# Frontend URL - must match exactly for CORS
# Development: http://localhost:5173
# Production: https://www.emmi-eu.com
ALLOWED_ORIGIN=https://www.emmi-eu.com

# ─── Proxy Configuration ─────────────────────────────────────────────────────
# Set to true if running behind Nginx, Cloudflare, or reverse proxy
# This ensures rate limits use the real client IP
TRUST_PROXY=true

# ─── Email Configuration (Zoho Mail) ─────────────────────────────────────────
# Zoho email address (your domain email)
# Example: support@emmi-eu.com
ZOHO_EMAIL=your-email@zoho.eu

# Zoho app password (NOT your regular password)
# Generate at: https://accounts.zoho.eu → My Account → Security → App Passwords
ZOHO_PASSWORD=your_zoho_app_password_here

# ─── Admin Email (for notifications) ─────────────────────────────────────────
# Email to receive booking notifications
ADMIN_EMAIL=admin@emmi-eu.com

# ─── Logging Configuration ──────────────────────────────────────────────────
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT SECURITY NOTES:
# ─────────────────────────────────────────────────────────────────────────────
# 1. Never share or commit your .env file
# 2. Use strong, random values for JWT_SECRET
# 3. Use separate credentials for production vs development
# 4. Rotate secrets regularly
# 5. Use environment variable management (e.g., AWS Secrets Manager)
# 6. Admin users are created in the database, not via environment variables
# 7. See backend/scripts/create-admin.js for creating admin users
# ─────────────────────────────────────────────────────────────────────────────

# ─── Payments (optional) ─────────────────────────────────────────────────────
# Leave empty if you do not want online payments yet.
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox or live
PAYPAL_ENV=sandbox
