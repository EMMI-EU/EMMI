# ─────────────────────────────────────────────────────────────────────────────
# EMMI Europe Tech — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit .env file to Git — only .env.example

# ─── API Configuration ──────────────────────────────────────────────────────
# Backend API URL (only used in development)
# In production, Nginx handles the proxy to /api/*
# Development: http://localhost:8080
# Production: (empty - Nginx proxies /api to backend automatically)
VITE_API_URL=http://localhost:8080

# ─── Analytics (optional) ───────────────────────────────────────────────────
# Google Analytics ID
# VITE_GA_ID=G-XXXXXXXXXX

# ─── Feature Flags (optional) ───────────────────────────────────────────────
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_CHAT_SUPPORT=false

# ─────────────────────────────────────────────────────────────────────────────
# NOTES:
# ─────────────────────────────────────────────────────────────────────────────
# - All VITE_* variables are publicly available in the frontend bundle
# - Never put secrets in frontend environment variables
# - In production, VITE_API_URL is typically empty (Nginx proxies)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Payments (optional, public frontend keys) ───────────────────────────────
VITE_STRIPE_PUBLIC_KEY=
VITE_PAYPAL_CLIENT_ID=
